@app.callback(
    Output('data-table-container', 'children'),
    [Input('data-type-selector', 'value'),
     Input('date-picker-range', 'start_date'),
     Input('date-picker-range', 'end_date')]
)
def update_data_table(data_type, start_date, end_date):
    mask = (gold_df['date'] >= start_date) & (gold_df['date'] <= end_date)
    
    if data_type == 'gold':
        data = gold_df[mask][['date', 'open', 'high', 'low', 'close', 'volume', 'rsi14', 'macd']]
    elif data_type == 'seller':
        data = seller_df[mask][['date', 'total_volume', 'not_shipped_ratio', 'minor_delay_ratio', 'major_delay_ratio']]
    else:
        data = events_df[mask]
    
    # 创建数据表格
    table = dbc.Table.from_dataframe(
        data.round(3).head(100),  # 限制显示行数
        striped=True,
        bordered=True,
        hover=True,
        responsive=True,
        className="mt-3"
    )
    
    return table
